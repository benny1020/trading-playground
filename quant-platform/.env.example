# ============================================================
# QuantLab Platform - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=quant
POSTGRES_PASSWORD=quantpass_change_me
POSTGRES_DB=quantdb

# --- Redis ---
REDIS_PASSWORD=

# --- MinIO (Object Storage) ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-...     # For paper analysis + strategy research

# --- Monitoring ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_change_me
FLOWER_USER=admin
FLOWER_PASSWORD=admin_change_me

# --- Jupyter ---
JUPYTER_TOKEN=quantlab2024_change_me

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

